{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GV OS",
  "version": "1.0.0",
  "identifier": "com.gv.studyos",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/"
  },
  "app": {
    "windows": [
      {
        "title": "GV-OS",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
